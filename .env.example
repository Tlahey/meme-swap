# meme-swap — Environment Configuration
# Copy this file to .env.local for local configuration

# Giphy API key (optional — for api-client package, not yet active)
# GIPHY_API_KEY=your_api_key_here

# FaceFusion execution providers (default: coreml,cpu for Apple Silicon)
# Options: coreml (Apple Silicon), cuda (NVIDIA), cpu (universal fallback)
# FACEFUSION_EXECUTION_PROVIDERS=coreml,cpu

# FaceFusion thread count (default: auto-detected based on CPU)
# FACEFUSION_THREAD_COUNT=8

# Web frontend port (default: 3010)
# PORT=3010

# MCP server port (default: 3001)
# MCP_PORT=3001
