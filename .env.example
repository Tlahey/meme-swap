# Meme Swap - Configuration
# Clonez ce fichier en .env.local pour la configuration locale

# Clé API Giphy (optionnel - pour l'API client)
# GIPHY_API_KEY=your_api_key_here

# FaceFusion - Fournisseurs d'exécution (défaut: coreml,cpu pour Mac Silicon)
# FACEFUSION_EXECUTION_PROVIDERS=coreml,cpu

# FaceFusion - Nombre de threads (défaut: auto)
# FACEFUSION_THREAD_COUNT=8

# Serveur - Port (défaut: 3000)
# PORT=3000
