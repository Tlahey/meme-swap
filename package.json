{
  "name": "meme-swap",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Swap faces in animated media using FaceFusion",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "frontend:dev": "turbo run dev --filter=frontend",
    "frontend:build": "turbo run build --filter=frontend",
    "desktop:dev": "turbo run dev --filter=desktop",
    "desktop:build": "turbo run build --filter=desktop",
    "desktop:package": "turbo run build && turbo run bundle && turbo run package --filter=desktop",
    "install:facefusion": "pnpm build --filter=@meme-swap/installer-core && node scripts/setup-facefusion.mjs",
    "release": "node scripts/prepare-release.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@meme-swap/installer-core": "workspace:*"
  },
  "devDependencies": {
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "prettier": "catalog:",
    "turbo": "^2.0.0",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18.0.0"
  }
}
