{
  "name": "desktop",
  "version": "0.3.4",
  "private": true,
  "description": "Meme Swap desktop application and automated installer for macOS",
  "main": "build/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc && copyfiles -u 1 src/**/*.html src/**/*.png build/",
    "package": "electron-builder",
    "lint": "eslint ."
  },
  "dependencies": {
    "@meme-swap/faceswap-core": "workspace:*",
    "@meme-swap/installer-core": "workspace:*",
    "@meme-swap/video-processor": "workspace:*"
  },
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "copyfiles": "^2.4.1",
    "@types/node": "catalog:"
  },
  "build": {
    "appId": "com.memeswap.desktop",
    "productName": "Meme Swap",
    "asar": true,
    "afterPack": "scripts/after-pack.cjs",
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "gatekeeperAssess": false,
      "identity": null
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../apps/frontend/out",
        "to": "apps/frontend/out",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../apps/mcp-server/bundle",
        "to": "apps/mcp-server/bundle",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../packages/faceswap-core/dist",
        "to": "packages/faceswap-core/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../packages/video-processor/dist",
        "to": "packages/video-processor/dist",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
